<!doctype html>
<!-- =============================================================================
  عهد · Ahd — Witnessed Money (deepened prototype)
  Single-file · OFFLINE (no network) · deterministic · Arabic RTL.
  Flow: problem → create qard-hassan agreement (AI Arabic terms + riba-clean check)
        → dual Nafath confirm → WITNESSED RECORD with a real SHA-256 hash-chain
        + a LIVE tamper-evident verifier → auto-settle via sarie → ذمّة محفوظة
        → Muqassa debt-netting (real greedy algorithm) with a CONSERVATION PROOF
          and a trust-network graph (kept-promises reputation — NOT a credit score).
  Deepened by Claude-Orchestrator to seal the Gauntlet teardown attacks:
    #2 "the record is a mocked hash → legal claim unproven"  → real SHA-256 chain
        + a verifier that DETECTS tampering live.
    #3 "netting is a cute graph, no analytical depth"        → conservation proof
        (every net position preserved to the halala) + the min-transfer bound.
  Built to the shared canonical model (00_Shared/contracts.md C2/C3/C4/C6).
  Rails (Nafath / sarie / ALLaM) are MOCKED behind clear seams (محاكاة);
  the SHA-256 record hashing, the chain, the schedule and the netting are really computed.
============================================================================= -->
<html lang="ar" dir="rtl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><text y='13' font-size='13'>📜</text></svg>">
<title>عهد · Ahd — المال بين الناس، موثَّقًا</title>
<style>
  :root{
    --teal:#0E7C66; --teal-d:#0A5C4C; --tint:#E7F2EF; --gold:#F2B705; --gold-soft:#FCEFC4;
    --bg:#F6F4EF; --surface:#fff; --ink:#15211E; --soft:#5B6B66; --line:#E2DED5;
    --danger:#C2410C; --danger-soft:#FCE8DD; --ok:#16A34A;
    --font:"IBM Plex Sans Arabic","SF Pro AR",system-ui,"Segoe UI",Tahoma,sans-serif;
    --mono:"SF Mono","Cascadia Code",ui-monospace,Menlo,Consolas,monospace;
    --r:16px; --r-lg:24px; --sh:0 8px 30px rgba(16,40,34,.10); --sh-lg:0 16px 48px rgba(16,40,34,.16);
  }
  *{box-sizing:border-box}
  html,body{margin:0;background:
     radial-gradient(1100px 600px at 90% -10%, #eef6f3 0, rgba(238,246,243,0) 60%),
     var(--bg);
     color:var(--ink);font-family:var(--font);direction:rtl}
  .num{unicode-bidi:plaintext;font-variant-numeric:tabular-nums}
  .mono{font-family:var(--mono);unicode-bidi:plaintext;direction:ltr;display:inline-block;letter-spacing:-.2px}
  .wrap{max-width:840px;margin:0 auto;padding:22px 16px 72px}
  .top{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:8px}
  .brand{display:flex;align-items:center;gap:12px}
  .logo{width:46px;height:46px;border-radius:13px;background:linear-gradient(135deg,var(--teal),var(--teal-d));
    color:#fff;display:grid;place-items:center;font-weight:800;font-size:24px;box-shadow:var(--sh)}
  .brand h1{font-size:22px;margin:0;font-weight:800;letter-spacing:-.3px}
  .brand p{margin:0;color:var(--soft);font-size:12.5px;font-weight:600}
  .steps{display:flex;gap:6px}
  .dot{width:9px;height:9px;border-radius:50%;background:var(--line);transition:.3s}
  .dot.on{background:var(--teal);transform:scale(1.25)}
  .dot.done{background:var(--gold)}
  .card{background:var(--surface);border:1px solid var(--line);border-radius:var(--r-lg);
    box-shadow:var(--sh);padding:30px;animation:rise .45s cubic-bezier(.2,.8,.2,1)}
  @keyframes rise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
  .pill{display:inline-flex;align-items:center;gap:6px;background:var(--tint);color:var(--teal);
    font-weight:700;font-size:12.5px;padding:5px 12px;border-radius:999px}
  h2{font-size:27px;line-height:1.25;margin:14px 0 8px;letter-spacing:-.4px}
  .sub{color:var(--soft);font-size:15px;line-height:1.7;margin:0}
  .stat{display:flex;gap:14px;flex-wrap:wrap;margin:22px 0}
  .stat>div{flex:1;min-width:150px;background:var(--bg);border:1px solid var(--line);border-radius:var(--r);padding:14px 16px}
  .stat b{display:block;font-size:26px;color:var(--teal-d);font-weight:800}
  .stat span{font-size:13px;color:var(--soft)}
  .ayah{margin:20px 0;padding:16px 20px;border-right:4px solid var(--gold);background:var(--gold-soft);
    border-radius:0 var(--r) var(--r) 0;font-size:16px;line-height:1.9}
  .ayah em{display:block;color:var(--soft);font-size:12.5px;font-style:normal;margin-top:6px}
  .btn{font-family:var(--font);font-size:16px;font-weight:700;background:var(--teal);color:#fff;border:0;
    border-radius:14px;padding:14px 26px;cursor:pointer;transition:.15s;box-shadow:var(--sh)}
  .btn:hover{background:var(--teal-d);transform:translateY(-1px)}
  .btn:active{transform:translateY(1px)}
  .btn.ghost{background:transparent;color:var(--teal);box-shadow:none;border:1.5px solid var(--line)}
  .btn.sm{font-size:13.5px;padding:9px 16px}
  .btn[disabled]{opacity:.45;cursor:not-allowed;transform:none}
  .row{display:flex;gap:14px;align-items:center;flex-wrap:wrap;margin-top:22px}
  .field{background:var(--bg);border:1px solid var(--line);border-radius:var(--r);padding:14px 16px;margin:10px 0}
  .field label{display:block;font-size:12.5px;color:var(--soft);font-weight:700;margin-bottom:4px}
  .field .v{font-size:18px;font-weight:700}
  .terms{background:var(--bg);border:1px dashed var(--teal);border-radius:var(--r);padding:18px 20px;line-height:1.95;font-size:15px;margin-top:8px}
  .terms .typing{border-left:2px solid var(--teal);animation:blink 1s steps(1) infinite}
  @keyframes blink{50%{border-color:transparent}}
  .badge{display:inline-flex;align-items:center;gap:7px;font-weight:800;font-size:13px;padding:7px 14px;border-radius:999px}
  .badge.ok{background:#E7F6EC;color:var(--ok)} .badge.gold{background:var(--gold-soft);color:#8a6d00}
  .badge.bad{background:var(--danger-soft);color:var(--danger)}
  .two{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:18px}
  @media(max-width:560px){.two{grid-template-columns:1fr}}
  .person{background:var(--bg);border:1px solid var(--line);border-radius:var(--r);padding:18px;text-align:center;transition:.25s}
  .person.confirmed{border-color:var(--ok);background:#F2FBF5}
  .ava{width:58px;height:58px;border-radius:50%;margin:0 auto 8px;display:grid;place-items:center;color:#fff;font-weight:800;font-size:22px}
  .face{font-size:13px;color:var(--soft);margin:2px 0 12px}
  .scan{height:6px;border-radius:6px;background:var(--line);overflow:hidden;margin-top:10px}
  .scan i{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--teal),var(--gold))}
  .doc{margin-top:18px;border:1px solid var(--line);border-radius:var(--r);overflow:hidden}
  .doc .hd{background:var(--teal-d);color:#fff;padding:12px 18px;font-weight:800;display:flex;justify-content:space-between;align-items:center;gap:10px}
  .doc .bd{padding:18px 20px;font-size:14px;line-height:1.9}
  .kv{display:flex;justify-content:space-between;gap:10px;padding:7px 0;border-bottom:1px dashed var(--line)}
  .kv:last-child{border:0}
  .kv span{color:var(--soft)} .kv b{font-weight:700}
  .kv.tampered b{color:var(--danger);text-decoration:line-through wavy}
  .seal{margin-top:6px;padding:12px 14px;background:#0d1f1b;color:#cfe8e0;border-radius:12px;font-size:12px;line-height:1.8}
  .seal .sr{display:flex;justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
  .seal .sr+.sr{margin-top:6px;border-top:1px solid #1d352f;padding-top:6px}
  .seal .lab{color:#7fae9f;font-weight:700;font-family:var(--font)}
  .hash{color:#9fe6c8}
  .hash.live{color:#ffd76b}
  .verify{margin-top:16px;border:1px solid var(--line);border-radius:var(--r);padding:16px}
  .vout{margin-top:12px}
  .vbox{padding:12px 14px;border-radius:12px;font-size:13.5px;line-height:1.8}
  .vbox.good{background:#E7F6EC;border:1px solid var(--ok)}
  .vbox.bad{background:var(--danger-soft);border:1px solid var(--danger)}
  .vbox b{font-weight:800}
  .cmp{display:flex;flex-direction:column;gap:4px;margin-top:8px;font-size:11.5px}
  .cmp div{display:flex;justify-content:space-between;gap:8px}
  .hint{font-size:12px;color:var(--soft);margin-top:8px;line-height:1.7}
  .sched{margin-top:14px}
  .inst{display:flex;align-items:center;gap:12px;padding:11px 14px;border:1px solid var(--line);border-radius:12px;margin:8px 0;transition:.3s}
  .inst.paid{background:#F2FBF5;border-color:var(--ok)}
  .inst .ic{width:30px;height:30px;border-radius:50%;display:grid;place-items:center;background:var(--bg);font-size:14px;flex:none}
  .inst.paid .ic{background:var(--ok);color:#fff}
  .inst .t{flex:1} .inst .t b{font-size:15px} .inst .t span{display:block;font-size:12px;color:var(--soft)}
  .cleared{margin-top:18px;text-align:center;padding:26px;border-radius:var(--r-lg);background:linear-gradient(135deg,var(--tint),#fff);border:1px solid var(--teal)}
  .cleared .big{font-size:30px;font-weight:800;color:var(--teal-d)}
  /* ---- Muqassa graph + proof ---- */
  .gwrap{margin-top:14px;background:var(--bg);border:1px solid var(--line);border-radius:var(--r);padding:8px 8px 2px}
  .gsvg{width:100%;height:auto;display:block;max-height:360px}
  .be{fill:none;stroke:#C6B9A4;stroke-width:1.6;opacity:.9;transition:opacity .5s}
  .se{fill:none;stroke:var(--gold);stroke-width:3.2;animation:dash .8s ease both}
  @keyframes dash{from{stroke-dasharray:260;stroke-dashoffset:260}to{stroke-dashoffset:0}}
  .ah{fill:#C6B9A4}.ahg{fill:var(--gold)}
  .ring-bg{fill:none;stroke:var(--line);stroke-width:4}
  .ring-fg{fill:none;stroke:var(--teal);stroke-width:4;stroke-linecap:round}
  .nodec{fill:#fff;stroke:var(--teal-d);stroke-width:1.6}
  .nlbl{text-anchor:middle;font-size:11px;font-weight:800;fill:var(--ink);font-family:var(--font)}
  .rlbl{text-anchor:middle;font-size:9px;font-weight:700;fill:var(--soft);font-family:var(--font)}
  .elbl{text-anchor:middle;font-size:9.5px;fill:#8a6d00;font-weight:700;font-family:var(--font);
    paint-order:stroke;stroke:#fff;stroke-width:3px}
  .cons{width:100%;border-collapse:collapse;margin-top:14px;font-size:13px}
  .cons th,.cons td{padding:8px 10px;border-bottom:1px solid var(--line);text-align:center}
  .cons th{color:var(--soft);font-weight:700;font-size:12px}
  .cons td:first-child{font-weight:700}
  .cons .deb{color:var(--danger)} .cons .cre{color:var(--ok)}
  .cons tfoot td{font-weight:800;border-top:2px solid var(--teal-d);border-bottom:0;background:var(--tint)}
  .count{display:flex;align-items:center;justify-content:center;gap:14px;margin:18px 0;font-weight:800}
  .count .from{font-size:40px;color:var(--danger)} .count .to{font-size:40px;color:var(--ok)}
  .count .arr{font-size:26px;color:var(--soft)}
  .foot{text-align:center;color:var(--soft);font-size:11.5px;margin-top:22px;line-height:1.7}
  .mock{display:inline-block;background:#fff5e6;color:#8a6d00;border:1px solid var(--gold);border-radius:6px;padding:1px 7px;font-size:10.5px;font-weight:700}
</style>
</head>
<body>
<div class="wrap">
  <div class="top">
    <div class="brand">
      <div class="logo">عـ</div>
      <div><h1>عَهد · Ahd</h1><p>المال بين الناس — مكتوبٌ، مشهودٌ، محفوظ</p></div>
    </div>
    <div class="steps" id="steps"></div>
  </div>
  <div id="app"></div>
  <div class="foot">
    نموذج أوّلي · يعمل دون اتصال · حتمي · واجهة عربية RTL ·
    <span class="mock">محاكاة</span> نفاذ / سريع / علّام —
    البصمة (SHA-256) والسلسلة والجدول والمقاصّة محسوبة فعليًا.
  </div>
</div>

<script>
"use strict";
/* ===AHD-LOGIC:BEGIN===  (pure, DOM-free, Node-testable — sliced by the test harness;
   the markers are inert comments and change nothing the browser renders) */
/* ============================================================================
   1) Real SHA-256 (pure JS, synchronous, offline, deterministic).
      Used for the witnessed-record content hash + the append-only hash-chain.
      (Production: both parties' Nafath/PKI signatures + an RFC-3161 timestamp
       token from a licensed TSP; here the HASHING is real, the PKI/TSA are seams.)
============================================================================ */
const K256=[
 0x428a2f98,0x71374491,0xb5c0fbcf,0xe9b5dba5,0x3956c25b,0x59f111f1,0x923f82a4,0xab1c5ed5,
 0xd807aa98,0x12835b01,0x243185be,0x550c7dc3,0x72be5d74,0x80deb1fe,0x9bdc06a7,0xc19bf174,
 0xe49b69c1,0xefbe4786,0x0fc19dc6,0x240ca1cc,0x2de92c6f,0x4a7484aa,0x5cb0a9dc,0x76f988da,
 0x983e5152,0xa831c66d,0xb00327c8,0xbf597fc7,0xc6e00bf3,0xd5a79147,0x06ca6351,0x14292967,
 0x27b70a85,0x2e1b2138,0x4d2c6dfc,0x53380d13,0x650a7354,0x766a0abb,0x81c2c92e,0x92722c85,
 0xa2bfe8a1,0xa81a664b,0xc24b8b70,0xc76c51a3,0xd192e819,0xd6990624,0xf40e3585,0x106aa070,
 0x19a4c116,0x1e376c08,0x2748774c,0x34b0bcb5,0x391c0cb3,0x4ed8aa4a,0x5b9cca4f,0x682e6ff3,
 0x748f82ee,0x78a5636f,0x84c87814,0x8cc70208,0x90befffa,0xa4506ceb,0xbef9a3f7,0xc67178f2];
function sha256bytes(bytes){
  let h0=0x6a09e667,h1=0xbb67ae85,h2=0x3c6ef372,h3=0xa54ff53a,
      h4=0x510e527f,h5=0x9b05688c,h6=0x1f83d9ab,h7=0x5be0cd19;
  const l=bytes.length, withOne=l+1, k=(56-(withOne%64)+64)%64, total=withOne+k+8;
  const m=new Uint8Array(total); m.set(bytes); m[l]=0x80;
  const dv=new DataView(m.buffer);
  const bitLen=l*8;
  dv.setUint32(total-4, bitLen>>>0, false);
  dv.setUint32(total-8, Math.floor(bitLen/0x100000000), false);
  const w=new Uint32Array(64);
  const rotr=(x,n)=>(x>>>n)|(x<<(32-n));
  for(let i=0;i<total;i+=64){
    for(let t=0;t<16;t++) w[t]=dv.getUint32(i+t*4,false);
    for(let t=16;t<64;t++){
      const s0=rotr(w[t-15],7)^rotr(w[t-15],18)^(w[t-15]>>>3);
      const s1=rotr(w[t-2],17)^rotr(w[t-2],19)^(w[t-2]>>>10);
      w[t]=(w[t-16]+s0+w[t-7]+s1)>>>0;
    }
    let a=h0,b=h1,c=h2,d=h3,e=h4,f=h5,g=h6,h=h7;
    for(let t=0;t<64;t++){
      const S1=rotr(e,6)^rotr(e,11)^rotr(e,25);
      const ch=(e&f)^((~e)&g);
      const t1=(h+S1+ch+K256[t]+w[t])>>>0;
      const S0=rotr(a,2)^rotr(a,13)^rotr(a,22);
      const maj=(a&b)^(a&c)^(b&c);
      const t2=(S0+maj)>>>0;
      h=g;g=f;f=e;e=(d+t1)>>>0;d=c;c=b;b=a;a=(t1+t2)>>>0;
    }
    h0=(h0+a)>>>0;h1=(h1+b)>>>0;h2=(h2+c)>>>0;h3=(h3+d)>>>0;
    h4=(h4+e)>>>0;h5=(h5+f)>>>0;h6=(h6+g)>>>0;h7=(h7+h)>>>0;
  }
  const hx=x=>('00000000'+(x>>>0).toString(16)).slice(-8);
  return hx(h0)+hx(h1)+hx(h2)+hx(h3)+hx(h4)+hx(h5)+hx(h6)+hx(h7);
}
const enc=new TextEncoder();
const sha256=str=>sha256bytes(enc.encode(str));
const short=(h,n)=>h.slice(0,n||16).toUpperCase();

/* ---------- formatting helpers (deterministic; no Date.now / no Math.random / no Intl) ----
   fmt() formats a whole number with comma thousands-grouping WITHOUT toLocaleString.
   Why: toLocaleString("en-US") depends on the runtime's ICU build — a small-ICU Node
   would drop the grouping ("5000" not "5,000"), so the SAME source could hash/display
   differently across environments. This hand-rolled grouping is byte-identical on every
   engine, locking determinism (and it feeds terms_ar → terms_hash, so it must be stable). */
function fmt(n){
  const r=Math.round(Number(n)||0), neg=r<0;
  const s=String(Math.abs(r)).replace(/\B(?=(\d{3})+(?!\d))/g,",");
  return neg?"-"+s:s;
}
/* ---------- money policy: integer minor units (halalas), never binary-float money ----
   1 SAR = 100 halala. Every value-bearing computation (the principal/installment that
   get hashed, and the Muqassa netting) runs on integers; SAR is a display projection. */
const MINOR=100;
const toMinor=sar=>Math.round(Number(sar)*MINOR);              // 5000 SAR -> 500000 halala
function minorToFixed2(minor){                                  // 500000 -> "5000.00"
  const a=Math.round(Math.abs(Number(minor)||0)), neg=minor<0;
  return (neg?"-":"")+Math.floor(a/MINOR)+"."+String(a%MINOR).padStart(2,"0");
}
const AR_MONTHS=["يناير","فبراير","مارس","أبريل","مايو","يونيو","يوليو","أغسطس","سبتمبر","أكتوبر","نوفمبر","ديسمبر"];

/* ============================================================================
   2) The Ahd object (shared canonical model — contracts.md C2).
      Amounts kept in SAR for the demo; production uses integer halalas (C2).
============================================================================ */
const AG={
  ahd_id:"AHD-01HZ-NOURA-SARA",
  type:"قرض حسن", lender:"نورة العتيبي", borrower:"سارة الزهراني",
  amount:5000, months:5, start:{y:2026,m:7},
  timestamp:"2026-07-01T10:30:00+03:00"
};
AG.amount_minor=toMinor(AG.amount);              // 500000 halala — the value-bearing principal
AG.installment_minor=Math.round(AG.amount_minor/AG.months); // 100000 halala (exact for 5000/5)
AG.installment=AG.installment_minor/MINOR;       // 1000 SAR — display projection only
AG.schedule=Array.from({length:AG.months},(_,i)=>{
  const m=((AG.start.m-1+i)%12), y=AG.start.y+Math.floor((AG.start.m-1+i)/12);
  return {label:`1 ${AR_MONTHS[m]} ${y}`,amount:AG.installment,paid:false};
});
/* the FROZEN plain-Arabic terms the parties actually sign (ALLaM-drafted, مُحاكاة) */
AG.terms_ar=`يُقِرّ الطرفان بأنّ «${AG.lender}» أقرضت «${AG.borrower}» مبلغ ${fmt(AG.amount)} ريال على سبيل القرض الحسن، يُسدَّد على ${AG.months} أقساطٍ شهريّةٍ متساوية قدر كلٍّ منها ${fmt(AG.installment)} ريال، دون أيّ زيادة أو فائدة أو غرامة تأخير. عند العجز يُمهَل المقترض بالمعروف.`;
AG.terms_hash=sha256(AG.terms_ar);
/* two-party Nafath consent (assurance NAFATH_BIOMETRIC) — signatures are seams,
   but each consent's signing-payload hash is real */
AG.consent=[
  {party:AG.lender, role:"المُقرِضة", assurance:"NAFATH_BIOMETRIC", signed_at:"2026-07-01T10:29:40+03:00"},
  {party:AG.borrower,role:"المقترضة",assurance:"NAFATH_BIOMETRIC", signed_at:"2026-07-01T10:29:58+03:00"}
];
AG.consent.forEach(c=>{ c.sig_ref="NFTH-"+short(sha256(c.party+"|"+c.assurance+"|"+c.signed_at+"|"+AG.terms_hash),10); });

/* Canonical serialization → the bytes that get hashed. `amt` lets the verifier
   recompute under a *tampered* value to prove any change breaks the seal. */
function canonical(amt){
  const aMinor=(amt==null?AG.amount_minor:toMinor(amt));   // integer halalas — no float money
  const instMinor=Math.round(aMinor/AG.months);
  const inst2=minorToFixed2(instMinor);                    // identical bytes to the old inst.toFixed(2)
  const sched=AG.schedule.map((s,i)=>`${i+1}:${s.label}:${inst2}`).join("|");
  return [
    "AHD-RECORD-v1",
    `ahd_id=${AG.ahd_id}`,
    `type=${AG.type}`,
    `lender=${AG.lender}`,
    `borrower=${AG.borrower}`,
    `principal=${minorToFixed2(aMinor)} SAR`,
    `months=${AG.months}`,
    `schedule=${sched}`,
    `terms_hash=${AG.terms_hash}`,
    `basis=Quran:2:282`,
    `riba=interest:false;late_penalty_to_lender:false;gharar:none`,
    `consent=${AG.consent.map(c=>`${c.party}#${c.assurance}#${c.signed_at}#${c.sig_ref}`).join(",")}`,
    `ts=${AG.timestamp}`
  ].join("\n");
}
/* The append-only chain (contracts.md C2 record_seal):
   genesis → block. seal = H(prev_hash + canonical_hash + seq). */
const GENESIS=sha256("AHD-CHAIN-GENESIS-ALINMA-2026");
/* named pure function — the seal primitive (kept separate so it is unit-testable) */
function sealBlock(prev,canonical_hash,seq){ return sha256(prev+canonical_hash+String(seq)); }
const SEALED={
  seq:1, prev:GENESIS,
  canonical_hash:sha256(canonical(null))
};
SEALED.seal=sealBlock(SEALED.prev,SEALED.canonical_hash,SEALED.seq);
/* recompute the seal from (possibly tampered) data — the verifier's core */
function recomputeSeal(amt){
  const ch=sha256(canonical(amt));
  return {canonical_hash:ch, seal:sealBlock(SEALED.prev,ch,SEALED.seq)};
}
/* named pure verifier: recompute → compare against the sealed value. Pure & deterministic;
   the on-screen runVerify() is a thin render wrapper over this. */
function verifyRecord(amt){
  const r=recomputeSeal(amt);
  return {ok:r.seal===SEALED.seal, sealed:SEALED.seal, recomputed:r.seal, canonical_hash:r.canonical_hash};
}

/* ============================================================================
   3) Muqassa — real greedy min-transfer netting + the conservation invariant.
============================================================================ */
const NODES=["نورة","سارة","خالد","ليلى","فهد"];
const IOUS=[
  {from:"نورة",to:"سارة",amount:200},{from:"سارة",to:"خالد",amount:200},
  {from:"نورة",to:"ليلى",amount:250},{from:"ليلى",to:"فهد",amount:250},
  {from:"نورة",to:"خالد",amount:400},{from:"نورة",to:"فهد",amount:50},
  {from:"سارة",to:"ليلى",amount:150},{from:"ليلى",to:"خالد",amount:150},
  {from:"خالد",to:"سارة",amount:150}
];
/* kept-promises reputation: [kept, total] — SOCIAL signal, NOT a credit score */
const REP={"نورة":[12,12],"سارة":[18,19],"خالد":[7,8],"ليلى":[22,23],"فهد":[5,6]};

function balancesOf(edges){
  const bal={}; NODES.forEach(n=>bal[n]=0);
  edges.forEach(e=>{bal[e.from]-=e.amount; bal[e.to]+=e.amount;});
  return bal; // >0 creditor (owed), <0 debtor (owes)
}
function netting(edges){
  const balSar=balancesOf(edges);
  /* integer-minor core: exact arithmetic, zero float epsilons. Build creditor/debtor
     lists in fixed NODES order so the result is deterministic before sorting. */
  const idx=n=>NODES.indexOf(n);
  const cred=[],deb=[];
  NODES.forEach(n=>{const v=toMinor(balSar[n]); if(v>0)cred.push({p:n,v}); else if(v<0)deb.push({p:n,v:-v});});
  /* sort by size desc; tie-break by fixed NODES index (NOT localeCompare, which is
     locale-dependent) so equal balances always resolve identically on every engine. */
  cred.sort((a,b)=>b.v-a.v || idx(a.p)-idx(b.p));
  deb.sort((a,b)=>b.v-a.v || idx(a.p)-idx(b.p));
  const out=[]; let i=0,j=0;
  while(i<deb.length&&j<cred.length){
    const m=Math.min(deb[i].v,cred[j].v);                  // integer halalas
    out.push({from:deb[i].p,to:cred[j].p,amount:m/MINOR}); // back to whole SAR (m is a multiple of MINOR)
    deb[i].v-=m; cred[j].v-=m;
    if(deb[i].v===0)i++; if(cred[j].v===0)j++;              // exact integer comparison
  }
  return out;
}
const BAL=balancesOf(IOUS);
const SETTLE=netting(IOUS);

/* ============================================================================
   4) Trust-network SVG (deterministic layout, reputation rings).
============================================================================ */
const CX=180,CY=158,RAD=112,NR=23;
function pos(name){const i=NODES.indexOf(name);const a=(-90+i*72)*Math.PI/180;return {x:CX+RAD*Math.cos(a),y:CY+RAD*Math.sin(a)};}
function shorten(a,b,r){const dx=b.x-a.x,dy=b.y-a.y,L=Math.hypot(dx,dy)||1;return {x:a.x+dx/L*r,y:a.y+dy/L*r};}
function edgeSVG(e,cls,label){
  const A=pos(e.from),B=pos(e.to);
  const a=shorten(A,B,NR+3), b=shorten(B,A,NR+9);
  const mx=(a.x+b.x)/2,my=(a.y+b.y)/2,dx=b.x-a.x,dy=b.y-a.y,L=Math.hypot(dx,dy)||1;
  const nx=-dy/L,ny=dx/L,bow=16, cx=mx+nx*bow, cy=my+ny*bow;
  const d=`M${a.x.toFixed(1)} ${a.y.toFixed(1)} Q${cx.toFixed(1)} ${cy.toFixed(1)} ${b.x.toFixed(1)} ${b.y.toFixed(1)}`;
  const mk=cls==='se'?'arwg':'arw';
  let s=`<path d="${d}" class="${cls}" marker-end="url(#${mk})"/>`;
  if(label) s+=`<text x="${cx.toFixed(1)}" y="${cy.toFixed(1)}" class="elbl">${fmt(e.amount)}</text>`;
  return s;
}
function nodeSVG(name){
  const p=pos(name),[kept,total]=REP[name],ratio=kept/total;
  const r=NR+5,C=2*Math.PI*r,dash=(ratio*C).toFixed(1),gap=(C-ratio*C+0.0001).toFixed(1);
  return `<g transform="translate(${p.x.toFixed(1)},${p.y.toFixed(1)})">
    <circle r="${r}" class="ring-bg"/>
    <circle r="${r}" class="ring-fg" stroke-dasharray="${dash} ${gap}" transform="rotate(-90)"/>
    <circle r="${NR}" class="nodec"/>
    <text class="nlbl" y="3">${name}</text>
    <text class="rlbl" y="${r+13}">${Math.round(ratio*100)}%</text>
  </g>`;
}
function graphSVG(mode){
  const edges=(mode==='after'?SETTLE.map(e=>edgeSVG(e,'se',true)):IOUS.map(e=>edgeSVG(e,'be',false))).join("");
  return `<svg viewBox="0 0 360 320" class="gsvg" role="img" aria-label="شبكة الديون">
    <defs>
      <marker id="arw" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" class="ah"/></marker>
      <marker id="arwg" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse"><path d="M0 0 L10 5 L0 10 z" class="ahg"/></marker>
    </defs>
    ${edges}${NODES.map(nodeSVG).join("")}</svg>`;
}

/* ============================================================================
   4.5) Riba/penalty rule engine — deterministic, offline, STATELESS regex.
        No /g flag anywhere ⇒ no RegExp.lastIndex carry-over between calls
        (a classic source of "works once, wrong the second time" nondeterminism).
        Kept here in the pure, Node-testable region so the harness can prove
        every rule hit and every miss against fixed vectors.
============================================================================ */
const RIBA_RULES=[
  {re:/(?:فائدة|الفائدة|ربا|ربوي|فايدة)/, why:"شرط فائدة/ربا على القرض", fix:"قرضٌ حسن بلا أيّ زيادة على الأصل"},
  {re:/(?:غرامة|عقوبة|جزاء)\s*(?:ال)?تأخير|غرامة|عقوبة|جزاء/, why:"غرامة تأخير لصالح المُقرِض", fix:"عند العُسر: نظرة إلى ميسرة (إمهال بالمعروف بلا زيادة)، أو إلتزام بالتبرّع لجهة خيرية"},
  {re:/(?:نسبة|٪|%|في\s*الم(?:ئة|ية)|بالمئة)/, why:"نسبة مئوية مرتبطة بمبلغ القرض", fix:"أجرة خدمةٍ ثابتة منفصلة عن القرض — لا نسبة من المبلغ"},
  {re:/(?:عمولة|زيادة|أرباح|ربح)/, why:"زيادة/عمولة على أصل الدَّين", fix:"الأصل فقط؛ أيّ رسمٍ يكون أجرة خدمةٍ ثابتة"}
];
function ribaScan(text){
  const t=(typeof text==="string"?text:(text==null?"":String(text))).trim();
  if(!t) return {verdict:"clean",hits:[]};
  const hits=RIBA_RULES.filter(r=>r.re.test(t));
  return {verdict:hits.length?"block":"clean", hits};
}
/* ===AHD-LOGIC:END===  (everything below this line touches the DOM — browser-only) */

/* ============================================================================
   5) State machine + step controller.
      ONE object (S) owns every piece of mutable demo state, and every transition
      goes through go(): it clamps the target, cancels all in-flight timers BEFORE
      swapping the DOM (kills the orphaned-timer-writes-to-detached-node bug), and
      falls back to a clean recoverable screen if a render ever throws.
============================================================================ */
const TOTAL=5;
const app=document.getElementById("app");
const S={ step:0, conf:{L:false,B:false}, scanW:{L:0,B:0},
          timers:{L:0,B:0,type:0}, tampered:false, recordIssued:false };
function clearTimers(){
  clearInterval(S.timers.L); clearInterval(S.timers.B); clearTimeout(S.timers.type);
  S.timers.L=0; S.timers.B=0; S.timers.type=0;
}
function resetState(){            /* deterministic clean slate — identical every run */
  clearTimers();
  S.conf={L:false,B:false}; S.scanW={L:0,B:0};
  S.tampered=false; S.recordIssued=false;
  AG.schedule.forEach(s=>s.paid=false);
}
function renderSteps(){
  const el=document.getElementById("steps"); if(!el) return;
  el.innerHTML=Array.from({length:TOTAL},(_,i)=>
    `<div class="dot ${i===S.step?'on':(i<S.step?'done':'')}"></div>`).join("");
}
const R=[];
function go(n){
  n=Math.max(0, Math.min(TOTAL-1, (n|0)));  /* clamp: the presenter can never reach an unbuilt screen */
  clearTimers();                            /* cancel scans/typing before the DOM changes underneath them */
  if(n===0) resetState();                   /* step 0 == guaranteed clean state for a fresh run */
  S.step=n; renderSteps();
  try{ R[n](); }
  catch(err){ renderFallback(err); }
  if(typeof window!=="undefined"&&window.scrollTo) window.scrollTo({top:0,behavior:"smooth"});
}
/* offline fallback: a clean, recoverable card (existing styles only) shown ONLY if a
   screen throws — never on the happy path. So even a total failure has a clean exit. */
function renderFallback(err){
  try{ console.error("[Ahd] render failure — recovered to a clean state:", err); }catch(_){}
  if(!app) return;
  app.innerHTML=`<div class="card">
    <span class="pill">عهد</span>
    <h2>تعذّر عرض هذه الخطوة.</h2>
    <p class="sub">حدثٌ غير متوقَّع — لا بيانات ضائعة. ابدأ العرض من جديد بحالةٍ نظيفة.</p>
    <div class="row"><button class="btn" onclick="go(0)">↺ إعادة من البداية</button></div>
  </div>`;
}

/* 0 — the problem */
R[0]=()=>{app.innerHTML=`<div class="card">
  <span class="pill">العهد · المال بين الناس</span>
  <h2>أكثر تعاملٍ ماليٍّ شيوعًا على الأرض… بلا منتج.</h2>
  <p class="sub">إقراض صديق، وعدٌ بالسداد، مبلغٌ بين أخوين. يجري على الذاكرة والثقة — فيكسرهما.</p>
  <div class="stat">
    <div><b class="num">~50%</b><span>لا يوثّقون القرض كتابةً أبدًا</span></div>
    <div><b class="num">1 من 6</b><span>علاقة دمّرها المال</span></div>
    <div><b class="num">~30%</b><span>من المقترضين لا يُعيدون كامل المبلغ</span></div>
  </div>
  <div class="ayah">﴿يَا أَيُّهَا الَّذِينَ آمَنُوا إِذَا تَدَايَنتُم بِدَيْنٍ إِلَىٰ أَجَلٍ مُّسَمًّى فَاكْتُبُوهُ﴾
    <em>سورة البقرة (٢٨٢) — أطول آية في القرآن، وأمرٌ صريح بتوثيق الدَّين والإشهاد عليه. لم يُبنَ له منتج… حتى الآن.</em></div>
  <p class="sub"><b>عهد</b> أول سكّة ماليّة للمال بين الناس: اتفاقٌ عادل، يشهده المصرف، ويُسوّى تلقائيًا.</p>
  <div class="row"><button class="btn" onclick="go(1)">لنبدأ — قرضٌ بين صديقتين ←</button></div>
</div>`};

/* 1 — create agreement + AI Arabic terms + riba-clean check */
R[1]=()=>{
  app.innerHTML=`<div class="card">
    <span class="pill">١ · إنشاء العهد</span>
    <h2>نورة تُقرض سارة <span class="num">${fmt(AG.amount)}</span> ر.س — قرضًا حسنًا.</h2>
    <div class="field"><label>النوع</label><div class="v">${AG.type} · بلا فائدة</div></div>
    <div class="row" style="margin:0">
      <div class="field" style="flex:1"><label>المبلغ</label><div class="v num">${fmt(AG.amount)} ر.س</div></div>
      <div class="field" style="flex:1"><label>السداد</label><div class="v num">${AG.months} أقساط شهرية</div></div>
    </div>
    <p class="sub" style="margin-top:14px">يصوغ <b>علّام</b> <span class="mock">محاكاة</span> الشروط بعربية واضحة ويتحقّق من خلوّها من الربا:</p>
    <div class="terms" id="terms"><span class="typing">…</span></div>
    <div id="check" style="margin-top:14px"></div>
    <div id="linter" style="margin-top:8px"></div>
    <div class="row"><button class="btn" id="next1" disabled>تأكيد الطرفين عبر نفاذ ←</button></div>
  </div>`;
  const txt=AG.terms_ar, el=document.getElementById("terms"); let i=0;
  (function type(){
    if(!el||!document.body.contains(el)) return; /* navigated away mid-typing → stop; never touch a detached node */
    if(i<=txt.length){el.innerHTML=txt.slice(0,i)+'<span class="typing"></span>';i+=2;S.timers.type=setTimeout(type,14);}
    else{el.textContent=txt; buildLinter();}
  })();
  const nx=document.getElementById("next1"); if(nx) nx.onclick=()=>go(2);
};

/* live riba/penalty linter (UI layer). The rule engine — RIBA_RULES + ribaScan() —
   now lives in the pure, Node-testable region above (section 4.5); buildLinter only
   renders the textarea and wires it to ribaScan, disabling the sign button on a hit. */
function buildLinter(){
  const _chk=document.getElementById("check"), _lnt=document.getElementById("linter");
  if(!_chk||!_lnt) return; /* DOM moved on (navigated away mid-typing) — nothing to render */
  document.getElementById("check").innerHTML=
    `<span class="badge ok">✓ خالٍ من الربا</span> &nbsp; <span class="badge ok">✓ لا غرامة تأخير</span> &nbsp; <span class="badge gold">قرض حسن مُوافِق للشريعة</span>`;
  document.getElementById("linter").innerHTML=`
    <div class="field" style="margin-top:8px">
      <label for="clause">جرِّب إضافة بندٍ إلى العهد — يفحصه «عهد» فورًا للتأكّد من خلوّه من الربا</label>
      <textarea id="clause" rows="2" placeholder="مثال: غرامة تأخير ٥٪ شهريًّا…"
        style="width:100%;font-family:var(--font);font-size:15px;border:1px solid var(--line);border-radius:12px;padding:10px 12px;background:#fff;resize:vertical;direction:rtl"></textarea>
      <div class="row" style="margin-top:8px;gap:8px">
        <button class="btn ghost sm" id="badchip" type="button">＋ غرامة تأخير ٥٪</button>
        <button class="btn ghost sm" id="clearchip" type="button">↩ امسح</button>
      </div>
      <div id="lintout" style="margin-top:10px"></div>
    </div>`;
  const ta=document.getElementById("clause"), out=document.getElementById("lintout"), next=document.getElementById("next1");
  function run(){
    const res=ribaScan(ta.value);
    if(res.verdict==="block"){
      out.innerHTML=`<div class="vbox bad"><b>✗ بندٌ مخالفٌ للشريعة — تعذّر التوثيق.</b>
        ${res.hits.map(h=>`<div style="margin-top:5px">• ${h.why} <span style="color:var(--soft)">→ البديل المُوافِق: ${h.fix}</span></div>`).join("")}</div>`;
      next.disabled=true; next.textContent="التوثيق متوقّف — أزِل البند المخالف";
    }else{
      out.innerHTML=ta.value.trim()?`<div class="vbox good"><b>✓ البند سليم</b> — خالٍ من الربا والغرامة؛ يمكن المتابعة.</div>`:"";
      next.disabled=false; next.textContent="تأكيد الطرفين عبر نفاذ ←";
    }
  }
  ta.addEventListener("input",run);
  document.getElementById("badchip").onclick=()=>{ta.value="غرامة تأخير ٥٪ شهريًّا عند تجاوز موعد السداد";run();ta.focus();};
  document.getElementById("clearchip").onclick=()=>{ta.value="";run();ta.focus();};
  run(); /* initial state: empty → CLEAN → sign button enabled */
}

/* 2 — dual Nafath confirm → witnessed record (real SHA-256 chain + verifier) */
R[2]=()=>{
  app.innerHTML=`<div class="card">
    <span class="pill">٢ · الإشهاد عبر نفاذ <span class="mock">محاكاة</span></span>
    <h2>يؤكّد الطرفان هويّتهما — فيُختَم العهد كدليلٍ لا يقبل العبث.</h2>
    <div class="two">
      ${personCard("L",AG.lender,"المُقرِضة","#0E7C66")}
      ${personCard("B",AG.borrower,"المقترضة","#8a6d00")}
    </div>
    <div id="record"></div>
    <div class="row"><button class="btn" id="next2" disabled>المتابعة إلى السداد ←</button></div>
  </div>`;
  /* fresh, clean cards on every entry to this step (idempotent re-runs) */
  S.conf={L:false,B:false}; S.scanW={L:0,B:0}; S.tampered=false; S.recordIssued=false;
};
function personCard(k,name,role,col){
  return `<div class="person" id="p${k}">
    <div class="ava" style="background:${col}">${name[0]}</div>
    <div style="font-weight:800">${name}</div><div class="face">${role}</div>
    <button class="btn ghost sm" onclick="confirmPerson('${k}')">📱 تأكيد ببصمة نفاذ</button>
    <div class="scan"><i id="scan${k}"></i></div>
  </div>`;
}
function confirmPerson(k){
  if(k!=="L"&&k!=="B") return;                 /* only the two known parties */
  if(S.conf[k]||S.timers[k]) return;           /* ignore double-taps: already confirmed, or a scan is running */
  const bar=document.getElementById("scan"+k), card=document.getElementById("p"+k);
  if(!bar||!card) return;                       /* defensive: card not on screen */
  S.scanW[k]=0;
  S.timers[k]=setInterval(()=>{
    const b=document.getElementById("scan"+k);
    if(!b){ clearInterval(S.timers[k]); S.timers[k]=0; return; }  /* navigated away → stop; no detached-node write */
    S.scanW[k]=Math.min(S.scanW[k]+8,100); b.style.width=S.scanW[k]+"%";
    if(S.scanW[k]>=100){
      clearInterval(S.timers[k]); S.timers[k]=0;
      const c=document.getElementById("p"+k); if(!c) return;
      c.classList.add("confirmed");
      const btn=c.querySelector("button"); if(btn) btn.outerHTML='<span class="badge ok">✓ مؤكَّد</span>';
      S.conf[k]=true;
      if(S.conf.L&&S.conf.B&&!S.recordIssued){ S.recordIssued=true; issueRecord(); }  /* issue exactly once */
    }
  },45);
}
function issueRecord(){
  S.tampered=false;
  const rec=document.getElementById("record"); if(!rec) return;   /* step changed under us → bail cleanly */
  rec.innerHTML=`<div id="docwrap"></div>
    <div class="verify">
      <div style="font-weight:800;font-size:14px">🔏 التحقّق من سلامة الدليل</div>
      <p class="hint">يُعيد المُحقِّق حساب البصمة من بيانات الوثيقة الآن، ويقارنها بالبصمة المختومة وقت التوثيق.
        أيّ تغيير — ولو ريال واحد — يكسر التطابق. هكذا تُثبَت سلامة الوثيقة رياضيًّا، فتكون <b>مهيّأةً لاستيفاء شروط القبول كدليلٍ إلكتروني</b> (نظام الإثبات ٢٠٢٢) — والقبول النهائي تقدير القاضي.</p>
      <div class="row" style="margin-top:12px">
        <button class="btn ghost sm" id="vbtn">🔎 تحقّق الآن</button>
        <button class="btn ghost sm" id="tbtn">🧪 جرّب العبث بالمبلغ</button>
      </div>
      <div class="vout" id="vout"></div>
    </div>`;
  renderDoc();
  const vb=document.getElementById("vbtn"); if(vb) vb.onclick=()=>runVerify();
  const tb=document.getElementById("tbtn");
  if(tb) tb.onclick=()=>{ S.tampered=!S.tampered; renderDoc(); runVerify();
    const t2=document.getElementById("tbtn"); if(t2) t2.textContent=S.tampered?"↩ استعد الوثيقة الأصلية":"🧪 جرّب العبث بالمبلغ"; };
  const nx=document.getElementById("next2"); if(nx){ nx.disabled=false; nx.onclick=()=>go(3); }
}
function renderDoc(){
  const amt=S.tampered?9000:AG.amount;
  const dw=document.getElementById("docwrap"); if(!dw) return;
  dw.innerHTML=`<div class="doc">
    <div class="hd"><span>📜 وثيقة عهد موثّقة</span>
      <span class="mono" style="font-size:11px;opacity:.85">#${short(SEALED.seal,12)}</span></div>
    <div class="bd">
      <div class="kv"><span>المُقرِضة</span><b>${AG.lender}</b></div>
      <div class="kv"><span>المقترضة</span><b>${AG.borrower}</b></div>
      <div class="kv ${S.tampered?'tampered':''}"><span>المبلغ</span><b class="num">${fmt(amt)} ر.س — قرض حسن</b></div>
      <div class="kv"><span>السداد</span><b class="num">${AG.months} أقساط شهرية</b></div>
      <div class="kv"><span>الإشهاد</span><b>${AG.consent.length} توقيعات نفاذ (بصمة)</b></div>
      <div class="kv"><span>الأساس</span><b>آية الدَّين · البقرة ٢٨٢</b></div>
      <div class="seal">
        <div class="sr"><span class="lab">بصمة المحتوى (SHA-256)</span><span class="hash mono">${short(SEALED.canonical_hash,24)}…</span></div>
        <div class="sr"><span class="lab">السلسلة — الكتلة السابقة</span><span class="hash mono">${short(SEALED.prev,16)}…</span></div>
        <div class="sr"><span class="lab">ختم الكتلة #${SEALED.seq}</span><span class="hash mono">${short(SEALED.seal,24)}…</span></div>
        <div class="sr"><span class="lab">الحالة</span><span style="color:#cfe8e0;font-family:var(--font);font-weight:700">مهيّأة كدليل إلكتروني · نظام الإثبات ٢٠٢٢ (القبول تقدير القاضي)</span></div>
      </div>
      ${S.tampered?'<p class="hint" style="color:var(--danger)">⚠️ عُدِّل المبلغ بعد التوثيق (٥٬٠٠٠ ← ٩٬٠٠٠). الوثيقة المختومة لم تتغيّر — اضغط «تحقّق الآن» لترى العبث مكشوفًا.</p>':''}
    </div></div>`;
}
function runVerify(){
  const v=verifyRecord(S.tampered?9000:null);   /* named pure verifier — recompute & compare */
  const out=document.getElementById("vout"); if(!out) return;
  if(v.ok){
    out.innerHTML=`<div class="vbox good">
      <b>✓ الوثيقة سليمة.</b> البصمة المحسوبة الآن تُطابق البصمة المختومة وقت التوثيق — لم يُمَسّ المحتوى.
      <div class="cmp">
        <div><span>المختوم</span><span class="mono">${short(v.sealed,28)}</span></div>
        <div><span>المحسوب الآن</span><span class="mono">${short(v.recomputed,28)}</span></div>
      </div></div>`;
  }else{
    out.innerHTML=`<div class="vbox bad">
      <b>✗ عبثٌ مكشوف!</b> تغيّر المبلغ ⇒ بصمةٌ مختلفة تمامًا. الدليل المختوم يفضح أيّ تعديل لاحق — وهذه سلامةٌ يستند إليها القاضي عند القبول.
      <div class="cmp">
        <div><span>المختوم وقت التوثيق</span><span class="mono">${short(v.sealed,28)}</span></div>
        <div><span>المحسوب من البيانات المعبوث بها</span><span class="mono hash live">${short(v.recomputed,28)}</span></div>
      </div></div>`;
  }
}

/* 3 — auto-settlement via sarie */
R[3]=()=>{
  AG.schedule.forEach(s=>s.paid=false);
  app.innerHTML=`<div class="card">
    <span class="pill">٣ · السداد التلقائي عبر سريع <span class="mock">محاكاة</span></span>
    <h2>يُسوّي «عهد» الأقساط تلقائيًا — بلا تذكير محرج.</h2>
    <p class="sub">كل أول شهر، يُحوّل القسط من سارة إلى نورة عبر سريع، ويُحدَّث العهد. <span class="hint" style="display:inline">(حدّ سريع ٢٠٬٠٠٠ ر.س للتحويل — القسط ١٬٠٠٠ ر.س ضمن الحدّ.)</span></p>
    <div class="sched" id="sched">${schedHtml()}</div>
    <div id="done3"></div>
    <div class="row"><button class="btn" id="skip">⏭️ تخطَّ الزمن — سوّ القسط التالي</button></div>
  </div>`;
  const sk=document.getElementById("skip"); if(sk) sk.onclick=settleNext;
};
function schedHtml(){return AG.schedule.map((s,i)=>`<div class="inst ${s.paid?'paid':''}" id="inst${i}">
  <div class="ic">${s.paid?'✓':(i+1)}</div>
  <div class="t"><b>القسط ${i+1} · <span class="num">${fmt(s.amount)}</span> ر.س</b><span>${s.label}${s.paid?' · سُدّد عبر سريع':''}</span></div>
</div>`).join("")}
function settleNext(){
  const i=AG.schedule.findIndex(s=>!s.paid); if(i<0) return;
  AG.schedule[i].paid=true;
  const sc=document.getElementById("sched"); if(sc) sc.innerHTML=schedHtml();
  if(AG.schedule.every(s=>s.paid)){
    const sk=document.getElementById("skip"); if(sk) sk.style.display="none";
    const dn=document.getElementById("done3"); if(!dn) return;
    dn.innerHTML=`<div class="cleared">
      <div style="font-size:40px">🤝</div>
      <div class="big">ذمّة محفوظة</div>
      <p class="sub" style="margin-top:6px">سُدّد القرض كاملًا. صداقةٌ سالمة، وعهدٌ مكتوبٌ وُفِّي به.</p>
      <div class="row" style="justify-content:center"><button class="btn" onclick="go(4)">والآن… دائرة كاملة من الديون ←</button></div>
    </div>`;
  }
}

/* 4 — Muqassa netting: trust-network graph + conservation proof (the data wow) */
R[4]=()=>{
  app.innerHTML=`<div class="card">
    <span class="pill">٤ · المقاصّة — تسوية الدائرة</span>
    <h2>خمسة أصدقاء، ديونٌ متشابكة. كم تحويلًا للتسوية؟</h2>
    <p class="sub">كلٌّ يَدين للآخر. «عهد» يحسب صافي كل طرف ويُسقط الدوائر — فتنحلّ الشبكة إلى تحويلاتٍ قليلة (لا تتجاوز عدد الأطراف ناقص واحد)، وكلُّ طرفٍ إمّا يدفع فقط أو يقبض فقط، مع الحفاظ على صافي كل شخص بالهللة.</p>
    <div class="gwrap" id="gwrap">${graphSVG('before')}</div>
    <p class="sub" style="text-align:center;font-size:12px;margin-top:6px">الحلقات الخارجية = <b>سجلّ الوفاء</b> (وعودٌ مكتملة) لكل شخص — سمعةٌ اجتماعية، <b>ليست تصنيفًا ائتمانيًا</b>.</p>
    <div class="row" style="justify-content:center"><button class="btn" id="run">⚡ شغّل المقاصّة</button></div>
    <div id="netout"></div>
  </div>`;
  document.getElementById("run").onclick=runMuqassa;
};
function runMuqassa(){
  const gw=document.getElementById("gwrap"); if(gw) gw.innerHTML=graphSVG('after');
  const rb=document.getElementById("run"); if(rb) rb.style.display="none";
  /* conservation: each person's pre-netting net == the cash they move in settlement.
     All values are whole-SAR integers (netting ran on integer halalas) → exact compares. */
  const move={}; NODES.forEach(n=>move[n]=0);
  SETTLE.forEach(s=>{move[s.from]-=s.amount; move[s.to]+=s.amount;});
  let totalPaid=0,totalRecv=0,allZero=true;
  const rows=NODES.map(n=>{
    const before=BAL[n], m=move[n], remaining=before-m;
    if(remaining!==0) allZero=false;
    if(m<0)totalPaid+=-m; if(m>0)totalRecv+=m;
    const beforeTxt = before<0?`<span class="deb">مدين ${fmt(-before)}</span>`
                    : before>0?`<span class="cre">دائن ${fmt(before)}</span>`:`<span>٠ — متوازن</span>`;
    const moveTxt = m<0?`يدفع <span class="num">${fmt(-m)}</span>`
                  : m>0?`يستلم <span class="num">${fmt(m)}</span>`:`—`;
    return `<tr><td>${n}</td><td>${beforeTxt}</td><td>${moveTxt}</td><td><b style="color:var(--ok)">٠ ✓</b></td></tr>`;
  }).join("");
  const no=document.getElementById("netout"); if(!no) return;
  no.innerHTML=`
    <div class="count"><span class="from num">${IOUS.length}</span><span class="arr">⟶</span><span class="to num">${SETTLE.length}</span></div>
    <p class="sub" style="text-align:center">شبكةٌ من <b>${IOUS.length}</b> التزامات… سُوِّيت بـ<b>${SETTLE.length}</b> تحويلين فقط، فورًا.
      الحدّ النظري لأي دائرة من <b>${NODES.length}</b> أطراف هو ${NODES.length-1} تحويلات على الأكثر — وصلنا إلى ٢.</p>
    <h4 style="margin:14px 0 0;font-size:14.5px">برهان الحفظ — لا مال يُخلق ولا يضيع</h4>
    <table class="cons">
      <thead><tr><th>الطرف</th><th>الصافي قبل المقاصّة</th><th>حركته في التسوية</th><th>المتبقّي</th></tr></thead>
      <tbody>${rows}</tbody>
      <tfoot><tr><td>الإجمالي</td><td class="deb">مدفوع ${fmt(totalPaid)}</td><td class="cre">مستلَم ${fmt(totalRecv)}</td><td>${allZero?'صفر صافٍ ✓':'⚠'}</td></tr></tfoot>
    </table>
    <p class="hint" style="text-align:center;margin-top:10px">صافي كل طرف بعد المقاصّة = صفر، ومجموع المدفوع = مجموع المستلَم (${fmt(totalPaid)} = ${fmt(totalRecv)}). خوارزمية حقيقية، تسويةٌ مُثبَتة الصحّة — لا مجرّد رسم.</p>
    <div class="row" style="justify-content:center"><button class="btn ghost" onclick="go(0)">↺ من البداية</button></div>`;
}

renderSteps();R[0]();
</script>
</body>
</html>
